# -----------------------------------------------------------------------------
# BIOLEADS - ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores reais.
# -----------------------------------------------------------------------------

# --- CONFIGURAÇÕES DO APP ---
PORT=3000
NODE_ENV=production
# URL do Frontend (Vercel)
NEXTAUTH_URL=https://bioleads.shop
# URL da API/Backend (VPS) - Importante para Webhooks
NEXT_PUBLIC_API_URL=https://api.bioleads.shop

# --- AUTENTICAÇÃO ---
# Gere uma chave aleatória: openssl rand -base64 32
NEXTAUTH_SECRET=sua_chave_secreta_aqui

# --- BANCO DE DADOS (SUPABASE) ---
# Use a porta 6543 para o Pooler (Transaction mode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
# Use a porta 5432 para conexão direta (Session mode)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- INTEGRAÇÃO WHATSAPP (EVOLUTION API) ---
EVOLUTION_API_URL=https://sua-instancia-evolution.com
EVOLUTION_GLOBAL_KEY=sua_global_key_aqui

# --- INTELIGÊNCIA ARTIFICIAL (OPCIONAL) ---
# Chave da Anthropic para o Agente Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxxx...

# --- SEGURANÇA CRON ---
# Chave para proteger o endpoint de follow-up
CRON_SECRET=sua_chave_cron_aqui
